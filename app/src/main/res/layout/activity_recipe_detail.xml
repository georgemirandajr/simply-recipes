<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@drawable/gradient_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Recipe Name -->
        <TextView
            android:id="@+id/recipeNameTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/navy_700"
            android:paddingBottom="8dp" />

        <EditText
            android:id="@+id/recipeNameEditText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/navy_700"
            android:paddingBottom="8dp"
            android:visibility="gone"
            android:inputType="text"
            android:hint="Recipe Name" />

        <!-- Fallback Message -->
        <TextView
            android:id="@+id/fallbackMessageTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/fallback_message"
            android:textSize="14sp"
            android:textStyle="italic"
            android:textColor="?android:attr/textColorSecondary"
            android:paddingBottom="8dp"
            android:visibility="gone" />

        <!-- Edit and Delete Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingBottom="16dp">

            <Button
                android:id="@+id/editButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="@string/edit_button"
                android:backgroundTint="@color/navy_200" />

            <Button
                android:id="@+id/deleteButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="@string/delete_button"
                android:backgroundTint="@color/navy_200" />
        </LinearLayout>

        <!-- Save and Cancel Buttons (Edit Mode) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingBottom="16dp">

            <Button
                android:id="@+id/saveButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="@string/save_button"
                android:backgroundTint="@color/navy_200"
                android:visibility="gone" />

            <Button
                android:id="@+id/cancelButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="@string/cancel_button"
                android:backgroundTint="@color/navy_200"
                android:visibility="gone" />
        </LinearLayout>

        <!-- Yield and Serving Size Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="16dp">

            <TextView
                android:id="@+id/yieldTextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:paddingBottom="4dp" />

            <EditText
                android:id="@+id/yieldEditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:paddingBottom="4dp"
                android:visibility="gone"
                android:inputType="text"
                android:hint="Yield (e.g., 4 servings)" />

            <TextView
                android:id="@+id/servingSizeTextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/servingSizeEditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:visibility="gone"
                android:inputType="text"
                android:hint="Serving Size (e.g., 1 cup)" />
        </LinearLayout>

        <!-- Category Selection Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/category_label"
                android:textSize="16sp"
                android:textStyle="bold"
                android:paddingBottom="8dp" />

            <Spinner
                android:id="@+id/categorySpinner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:popupBackground="?attr/colorSurface"
                android:minHeight="48dp" />
        </LinearLayout>

        <!-- Scaling Controls Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/scaling_label"
                android:textSize="16sp"
                android:textStyle="bold"
                android:paddingBottom="8dp" />

            <RadioGroup
                android:id="@+id/scalingRadioGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <RadioButton
                    android:id="@+id/scaling1xRadioButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/scaling_1x"
                    android:textColor="@color/navy_700"
                    android:checked="true" />

                <RadioButton
                    android:id="@+id/scaling1_5xRadioButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/scaling_1_5x"
                    android:textColor="@color/navy_700" />

                <RadioButton
                    android:id="@+id/scaling2xRadioButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/scaling_2x"
                    android:textColor="@color/navy_700" />
            </RadioGroup>
        </LinearLayout>

        <!-- Ingredients Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/ingredients_header"
                android:textSize="18sp"
                android:textStyle="bold"
                android:paddingBottom="8dp" />

            <LinearLayout
                android:id="@+id/ingredientsListLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </LinearLayout>

        <!-- Instructions Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/instructions_header"
                android:textSize="18sp"
                android:textStyle="bold"
                android:paddingBottom="8dp" />

            <!-- Scaling Warning Notification -->
            <TextView
                android:id="@+id/scalingWarningTextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/scaling_warning"
                android:textSize="12sp"
                android:textStyle="italic"
                android:textColor="?android:attr/textColorSecondary"
                android:paddingBottom="8dp"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/instructionsListLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </LinearLayout>

        <!-- Nutrition Information Section -->
        <LinearLayout
            android:id="@+id/nutritionSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/nutrition_header"
                android:textSize="18sp"
                android:textStyle="bold"
                android:paddingBottom="8dp" />

            <TextView
                android:id="@+id/nutritionInfoTextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/nutritionInfoEditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:visibility="gone"
                android:inputType="textMultiLine"
                android:minLines="3"
                android:gravity="start|top"
                android:hint="Nutrition Info (e.g., Calories: 250\nProtein: 10g)" />
        </LinearLayout>

        <!-- Original Link Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/original_link_label"
                android:textSize="16sp"
                android:textStyle="bold"
                android:paddingBottom="8dp" />

            <TextView
                android:id="@+id/originalLinkTextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textColor="@color/navy_200"
                android:autoLink="web"
                android:linksClickable="true" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
